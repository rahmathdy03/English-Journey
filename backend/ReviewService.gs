function getReviewList_(user){const v=valuesAsObjects_('VocabularyProgress').filter(x=>String(x.user_id)===String(user.user_id)&&Number(x.wrong_count||0)>0&&String(x.status)!=='mastered').map(x=>({itemType:'vocabulary',itemId:x.word_id,title:x.word,description:'Review the meaning and use it in a sentence.',wrongCount:Number(x.wrong_count||0),correctCount:Number(x.correct_count||0)})),g=valuesAsObjects_('GrammarProgress').filter(x=>String(x.user_id)===String(user.user_id)&&Number(x.wrong_count||0)>0&&String(x.status)!=='completed').map(x=>({itemType:'grammar',itemId:x.grammar_id,title:x.grammar_title,description:'Review the formula and common mistake.',wrongCount:Number(x.wrong_count||0),correctCount:Number(x.correct_count||0)}));return{items:v.concat(g).sort((a,b)=>b.wrongCount-a.wrongCount),summary:{vocabulary:v.length,grammar:g.length}}}function submitReview_(user,payload){const type=requireString_(payload.itemType,'itemType',20),id=requireString_(payload.itemId,'itemId',100),correct=requireBoolean_(payload.correct,'correct');if(type==='vocabulary'){const r=findOne_('VocabularyProgress',x=>String(x.user_id)===String(user.user_id)&&String(x.word_id)===id);if(!r)throw appError_('Review item not found.','NOT_FOUND');const c=Number(r.correct_count||0)+(correct?1:0),w=Number(r.wrong_count||0)+(correct?0:1),status=c>=3?'mastered':w>=2?'difficult':'learning';updateObjectRow_('VocabularyProgress',r._row,{correct_count:c,wrong_count:w,status:status,last_reviewed:nowIso_(),updated_at:nowIso_()})}else if(type==='grammar'){const r=findOne_('GrammarProgress',x=>String(x.user_id)===String(user.user_id)&&String(x.grammar_id)===id);if(!r)throw appError_('Review item not found.','NOT_FOUND');const c=Number(r.correct_count||0)+(correct?1:0),w=Number(r.wrong_count||0)+(correct?0:1),a=c/(c+w)*100;updateObjectRow_('GrammarProgress',r._row,{correct_count:c,wrong_count:w,accuracy:a,status:a>=80&&c>=3?'completed':w>=2?'needs review':'learning',updated_at:nowIso_()})}else throw appError_('Invalid item type.','VALIDATION_ERROR');recalculateUserStats_(user.user_id);return{saved:true}}