function achievementUnlocked_(id,userId){const u=findOne_('Users',x=>String(x.user_id)===String(userId)),daily=valuesAsObjects_('DailyProgress').filter(x=>String(x.user_id)===String(userId)&&bool_(x.daily_completed)),history=valuesAsObjects_('LearningHistory').filter(x=>String(x.user_id)===String(userId)),weekly=valuesAsObjects_('WeeklyProgress').filter(x=>String(x.user_id)===String(userId)&&bool_(x.challenge_completed));if(id==='first-lesson')return daily.length>=1;if(id==='first-perfect')return history.some(x=>Number(x.score)===100);if(id==='streak-7')return Number(u.best_streak)>=7;if(id==='streak-30')return Number(u.best_streak)>=30;if(id==='vocab-50')return Number(u.total_words)>=50;if(id==='vocab-100')return Number(u.total_words)>=100;if(id==='grammar-beginner')return valuesAsObjects_('GrammarProgress').filter(x=>String(x.user_id)===String(userId)).length>=6;if(id==='grammar-master')return Number(u.grammar_accuracy)>=90;if(id==='weekly-champion')return weekly.length>=1;if(id==='perfect-week')return weekly.some(x=>Number(x.final_score)===100);if(id==='learn-together')return APP_CONFIG.USERS.every(z=>valuesAsObjects_('DailyProgress').some(x=>String(x.user_id)===z.userId&&bool_(x.daily_completed)));return false}function evaluateAchievements_(userId){ACHIEVEMENT_DEFINITIONS.forEach(function(a){if(achievementUnlocked_(a.id,userId)&&!findOne_('Achievements',x=>String(x.user_id)===String(userId)&&String(x.achievement_id)===a.id)){appendObject_('Achievements',{id:uuid_(),user_id:userId,achievement_id:a.id,achievement_name:a.name,unlocked:true,unlocked_at:nowIso_()})}})}function getAchievements_(user){evaluateAchievements_(user.user_id);const unlocked=valuesAsObjects_('Achievements').filter(x=>String(x.user_id)===String(user.user_id)&&bool_(x.unlocked)).map(x=>String(x.achievement_id));const items=ACHIEVEMENT_DEFINITIONS.map(a=>Object.assign({},a,{unlocked:unlocked.indexOf(a.id)>=0}));return{items:items,unlockedCount:items.filter(x=>x.unlocked).length,totalCount:items.length}}