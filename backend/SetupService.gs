function setupEnglishJourney(){const props=PropertiesService.getScriptProperties();if(!props.getProperty('PIN_SALT'))props.setProperty('PIN_SALT',randomToken_());let id=props.getProperty('SPREADSHEET_ID'),ss;if(id){ss=SpreadsheetApp.openById(id)}else{ss=SpreadsheetApp.create('English Journey Data');props.setProperty('SPREADSHEET_ID',ss.getId())}Object.keys(HEADERS).forEach(function(name){let s=ss.getSheetByName(name);if(!s)s=ss.insertSheet(name);s.clear();s.getRange(1,1,1,HEADERS[name].length).setValues([HEADERS[name]]);s.setFrozenRows(1);s.autoResizeColumns(1,HEADERS[name].length)});seedUsers_();configurePinsFromTemporaryProperties();return{spreadsheetId:ss.getId(),spreadsheetUrl:ss.getUrl(),message:'Setup complete. Deploy the project as a Web App.'}}function seedUsers_(){const t=nowIso_();APP_CONFIG.USERS.forEach(function(u){appendObject_('Users',{user_id:u.userId,display_name:u.displayName,avatar:u.avatar,current_week:1,current_day:1,current_streak:0,best_streak:0,total_words:0,mastered_words:0,grammar_accuracy:0,average_score:0,last_study_date:'',daily_target:20,streak_target:30,vocabulary_target:300,created_at:t,updated_at:t})})}function configurePinsFromTemporaryProperties(){const p=PropertiesService.getScriptProperties(),f=p.getProperty('SETUP_FINKA_PIN'),r=p.getProperty('SETUP_RAHMAT_PIN');if(!f||!r)throw appError_('Add temporary SETUP_FINKA_PIN and SETUP_RAHMAT_PIN Script Properties first.','PIN_SETUP_REQUIRED');if(!/^\d{4,10}$/.test(f)||!/^\d{4,10}$/.test(r))throw appError_('PIN must contain 4–10 digits.','PIN_SETUP_INVALID');p.setProperty('USER_FINKA_PIN_HASH',hashPin_('finka',f));p.setProperty('USER_RAHMAT_PIN_HASH',hashPin_('rahmat',r));p.deleteProperty('SETUP_FINKA_PIN');p.deleteProperty('SETUP_RAHMAT_PIN');return'PIN hashes configured; temporary PIN properties deleted.'}