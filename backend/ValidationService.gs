function requireString_(value,name,max){if(typeof value!=='string'||!value.trim())throw appError_(name+' is required.','VALIDATION_ERROR');const v=value.trim();if(max&&v.length>max)throw appError_(name+' is too long.','VALIDATION_ERROR');return v}function requireInteger_(value,name,min,max){const n=Number(value);if(!Number.isInteger(n)||(min!=null&&n<min)||(max!=null&&n>max))throw appError_(name+' is invalid.','VALIDATION_ERROR');return n}function requireBoolean_(value,name){if(typeof value!=='boolean')throw appError_(name+' must be true or false.','VALIDATION_ERROR');return value}function sanitizeText_(value,max){return String(value==null?'':value).replace(/[<>]/g,'').trim().slice(0,max||200)}function validateAction_(a){return requireString_(a,'action',60).replace(/[^a-zA-Z0-9_]/g,'')}