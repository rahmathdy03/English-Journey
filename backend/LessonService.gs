function getDayContent_(week,day){const w=LESSON_DATA[week],d=w&&w.days.find(x=>Number(x.day)===Number(day));if(!d)throw appError_('Content for this week/day has not been added yet.','CONTENT_NOT_AVAILABLE');return d}function getDailyLesson_(user,payload){const week=payload.week?requireInteger_(payload.week,'week',1,999):Number(user.current_week),day=payload.day?requireInteger_(payload.day,'day',1,7):null;if(day==null){const w=LESSON_DATA[week],daily=valuesAsObjects_('DailyProgress').filter(x=>String(x.user_id)===String(user.user_id)&&Number(x.week)===week);const days=[];for(let d=1;d<=7;d++){const row=daily.find(x=>Number(x.day)===d),completed=d===7?!!findOne_('WeeklyProgress',x=>String(x.user_id)===String(user.user_id)&&Number(x.week)===week&&bool_(x.challenge_completed)):row&&bool_(row.daily_completed),accessible=d===7?daily.filter(x=>Number(x.day)<=6&&bool_(x.daily_completed)).length===6:lessonAccessible_(user,week,d);let content=w&&w.days.find(x=>x.day===d);days.push({day:d,title:content?content.title:'Content coming soon',vocabularyCount:content?content.vocabulary.length:0,grammarTitle:content?content.grammar.title:'',status:completed?'completed':accessible?'active':'locked'})}return{week:week,currentDay:Number(user.current_day),completedDays:days.filter(x=>x.status==='completed').length,days:days}}if(day===7)throw appError_('Open the Weekly Challenge page for Day 7.','USE_WEEKLY_CHALLENGE');const locked=!lessonAccessible_(user,week,day),lesson=locked?null:getDayContent_(week,day),row=dailyRow_(user.user_id,week,day,false);return{week:week,day:day,locked:locked,lesson:lesson,status:progressStatus_(row)}}function completeVocabularyLesson_(user,payload){const week=requireInteger_(payload.week,'week',1,999),day=requireInteger_(payload.day,'day',1,6);if(!lessonAccessible_(user,week,day))throw appError_('This lesson is locked.','LESSON_LOCKED');return withWriteLock_(function(){const content=getDayContent_(week,day),row=dailyRow_(user.user_id,week,day,true);content.