function weeklyUnlocked_(userId,week){const rows=valuesAsObjects_('DailyProgress').filter(x=>String(x.user_id)===String(userId)&&Number(x.week)===Number(week)&&Number(x.day)<=6&&bool_(x.daily_completed));return new Set(rows.map(x=>Number(x.day))).size===6}function weeklyQuestions_(week){return QUESTION_BANK.filter(q=>Number(q.week)===Number(week)&&q.quizType==='weekly')}function getWeeklyChallenge_(user,payload){const week=requireInteger_(payload.week,'week',1,999),existing=findOne_('WeeklyProgress',x=>String(x.user_id)===String(user.user_id)&&Number(x.week)===week&&bool_(x.challenge_completed));if(existing)return{completed:true,unlocked:true,result:{finalScore:Number(existing.final_score),vocabularyScore:Number(existing.vocabulary_score),grammarScore:Number(existing.grammar_score),mixedScore:Number(existing.mixed_score)}};const unlocked=weeklyUnlocked_(user.user_id,week),qs=unlocked?weeklyQuestions_(week):[];return{completed:false,unlocked:unlocked,questions:qs.map(publicQuestion_)}}function submitWeeklyChallenge_(user,payload){const week=requireInteger_(payload.week,'week',1,999),answers=payload.answers;if(!weeklyUnlocked_(user.user_id,week))throw appError_('Complete Day 1 through Day 6 first.','WEEKLY_LOCKED');if(!Array.isArray(answers))throw appError_('answers must be an array.','VALIDATION_ERROR');const qs=weeklyQuestions_(week),by={};answers.forEach(a=>by[String(a.questionId)]=String(a.answer==null?'':a.answer));let correct=0,vC=0,vT=0,gC=0,gT=0,mC=0,mT=0;const mistakes=[];qs.forEach(function(q){const ok=safeEqual_(by[q.id]||'',q.answer);if(ok)correct++;else mistakes.push({prompt:q.prompt,userAnswer:by[q.id]||'',correctAnswer:q.answer,explanation:q.explanation});if(q.weeklyGroup==='vocabulary'){vT++;if(ok)vC++}else if(q.weeklyGroup==='grammar'){gT++;if(ok)gC++}else{mT++;if(ok)mC++}updateLearningItem_(user.user_id,q,ok)});const finalScore=Math.round(correct/qs.length*100),v=Math.round(vC/Math.max(1,vT)*100),g=Math.round(gC/Math.max(1,gT)*100),m=Math.round(mC/Math.max(1,mT)*100);return withWriteLock_(function(){let r=findOne_('WeeklyProgress',x=>String(x.user_id)===String(user.user_id)&&Number(x.week)===week);const data={id:r?r.id:uuid_(),user_id:user.user_id,week:week,vocabulary_score:v,grammar_score:g,mixed_score:m,final_score:finalScore,challenge_completed:true,reward_claimed:true,completed_at:nowIso_()};if(r)updateObjectRow_('WeeklyProgress',r._row,data);else appendObject_('WeeklyProgress',data);updateObjectRow_('Users',user._row,{current_week:week+1,current_day:1,updated_at:nowIso_()});recalculateUserStats_(user.user_id);evaluateAchievements_(user.user_id);const partnerDone=APP_CONFIG.USERS.every(z=>!!findOne_('WeeklyProgress',x=>String(x.user_id)===z.userId&&Number(x.week)===week&&bool_(x.challenge_completed)));return{finalScore:finalScore,vocabularyScore:v,grammarScore:g,mixedScore:m,mistakes:mistakes,xp:100+finalScore,totalVocabulary:Number(findOne_('Users',x=>String(x.user_id)===String(user.user_id)).total_words||0),message:partnerDone?'Congratulations! You both completed this week together. Keep growing together.':'Week '+(week+1)+' unlocked!'}})}