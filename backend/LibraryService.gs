function getVocabularyLibrary_(user){const rows=valuesAsObjects_('VocabularyProgress').filter(x=>String(x.user_id)===String(user.user_id)),all=allVocabulary_();return{items:rows.map(r=>{const w=all.find(x=>x.id===r.word_id)||{};return{wordId:r.word_id,word:r.word,meaning:w.meaning||'',phonetic:w.phonetic||'',example:w.example||'',week:Number(r.week),day:Number(r.day),status:String(r.status||'learning'),isFavorite:bool_(r.is_favorite)}})}}function getGrammarLibrary_(user){let items=[];Object.keys(LESSON_DATA).forEach(k=>LESSON_DATA[k].days.forEach(d=>{const g=d.grammar,r=findOne_('GrammarProgress',x=>String(x.user_id)===String(user.user_id)&&String(x.grammar_id)===g.id),accessible=lessonAccessible_(user,Number(k),d.day);items.push({grammarId:g.id,title:g.title,function:g.function,level:g.level,week:Number(k),day:d.day,status:r?(String(r.status)==='learning'?'available':String(r.status)):accessible?'available':'locked'})}));return{items:items}}