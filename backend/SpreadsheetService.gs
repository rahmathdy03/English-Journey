function spreadsheet_(){const id=PropertiesService.getScriptProperties().getProperty('SPREADSHEET_ID');if(!id)throw appError_('SPREADSHEET_ID is not configured.','SETUP_REQUIRED');return SpreadsheetApp.openById(id)}function sheet_(name){const s=spreadsheet_().getSheetByName(name);if(!s)throw appError_('Missing sheet: '+name,'SETUP_REQUIRED');return s}function valuesAsObjects_(name){const s=sheet_(name),v=s.getDataRange().getValues();if(v.length<2)return[];const h=v[0].map(String);return v.slice(1).filter(r=>r.some(x=>x!==''&&x!=null)).map((r,ri)=>{const o={_row:ri+2};h.forEach((k,i)=>o[k]=r[i]);return o})}function appendObject_(name,obj){const h=HEADERS[name];sheet_(name).appendRow(h.map(k=>obj[k]!==undefined?obj[k]:''));return obj}function updateObjectRow_(name,row,obj){const s=sheet_(name),h=HEADERS[name],current=s.getRange(row,1,1,h.length).getValues()[0];const values=h.map((k,i)=>obj[k]!==undefined?obj[k]:current[i]);s.getRange(row,1,1,h.length).setValues([values]);return obj}function findOne_(name,predicate){return valuesAsObjects_(name).find(predicate)||null}function withWriteLock_(fn){const l=LockService.getScriptLock();l.waitLock(20000);try{return fn()}finally{l.releaseLock()}}function nowIso_(){return new Date().toISOString()}function dateKey_(d){return Utilities.formatDate(d||new Date(),Session.getScriptTimeZone()||'Asia/Jakarta','yyyy-MM-dd')}function uuid_(){return Utilities.getUuid()}