function login_(payload){const userId=requireString_(payload.userId,'userId',30).toLowerCase(),pin=requireString_(payload.pin,'pin',10);if(!/^\d{4,10}$/.test(pin))throw appError_('Invalid PIN format.','AUTH_INVALID_PIN');const user=findOne_('Users',u=>String(u.user_id)===userId);if(!user)throw appError_('User not found.','AUTH_INVALID_CREDENTIALS');enforceRateLimit_(userId,'login');const stored=PropertiesService.getScriptProperties().getProperty('USER_'+userId.toUpperCase()+'_PIN_HASH');if(!stored||!safeEqual_(stored,hashPin_(userId,pin)))throw appError_('Incorrect PIN.','AUTH_INVALID_CREDENTIALS');const token=randomToken_(),expires=new Date(Date.now()+APP_CONFIG.SESSION_HOURS*3600000);appendObject_('Sessions',{session_id:uuid_(),user_id:userId,token_hash:hashText_(token),expires_at:expires.toISOString(),created_at:nowIso_()});return{token:token,expiresAt:expires.toISOString(),user:{userId:user.user_id,displayName:user.display_name,avatar:user.avatar}}}function logout_(payload){const token=requireString_(payload.sessionToken,'sessionToken',500),h=hashText_(token),s=findOne_('Sessions',x=>String(x.token_hash)===h);if(s)sheet_('Sessions').deleteRow(s._row);return{loggedOut:true}}function authenticate_(payload){const token=requireString_(payload.sessionToken,'sessionToken',500),h=hashText_(token),session=findOne_('Sessions',x=>String(x.token_hash)===h);if(!session||new Date(session.expires_at).getTime()<=Date.now()){if(session)sheet_('Sessions').deleteRow(session._row);throw appError_('Invalid or expired session.','AUTH_INVALID_SESSION')}const user=findOne_('Users',u=>String(u.user_id)===String(session.user_id));if(!user)throw appError_('User no longer exists.','AUTH_INVALID_SESSION');enforceRateLimit_(user.user_id,payload.action||'request');return user}