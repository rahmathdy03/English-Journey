function getProfile_(user){return{userId:user.user_id,displayName:user.display_name,avatar:user.avatar,currentWeek:Number(user.current_week),currentDay:Number(user.current_day),dailyTarget:Number(user.daily_target||20),streakTarget:Number(user.streak_target||30),vocabularyTarget:Number(user.vocabulary_target||300)}}function updateProfile_(user,payload){const name=sanitizeText_(requireString_(payload.displayName,'displayName',40),40),avatar=requireString_(payload.avatar,'avatar',40);if(['finka.svg','rahmat.svg'].indexOf(avatar)<0)throw appError_('Invalid avatar.','VALIDATION_ERROR');const daily=requireInteger_(payload.dailyTarget,'dailyTarget',5,180),streak=requireInteger_(payload.streakTarget,'streakTarget',1,365),vocab=requireInteger_(payload.vocabularyTarget,'vocabularyTarget',30,5000);updateObjectRow_('Users',user._row,{display_name:name,avatar:avatar,daily_target:daily,streak_target:streak,vocabulary_target:vocab,updated_at:nowIso_()});return{saved:true,profile:getProfile_(findOne_('Users',x=>String(x.user_id)===String(user.user_id)))}}
function updatePin_(user,payload){const current=requireString_(payload.currentPin,'currentPin',10),next=requireString_(payload.newPin,'newPin',10);if(!/^\d{4,10}$/.test(next))throw appError_('New PIN must contain 4–10 digits.','VALIDATION_ERROR');const props=PropertiesService.getScriptProperties(),key='USER_'+String(user.user_id).toUpperCase()+'_PIN_HASH',stored=props.getProperty(key);if(!stored||!safeEqual_(stored,hashPin_(user.user_id,current)))throw appError_('Current PIN is incorrect.','AUTH_INVALID_CREDENTIALS');if(safeEqual_(current,next))throw appError_('New PIN must be different.','VALIDATION_ERROR');props.setProperty(key,hashPin_(user.user_id,next));return{saved:true}}
