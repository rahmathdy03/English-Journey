function successResponse_(message,data){return ContentService.createTextOutput(JSON.stringify({success:true,message:message||'Success',data:data||{}})).setMimeType(ContentService.MimeType.JSON)}function errorResponse_(message,code,data){return ContentService.createTextOutput(JSON.stringify({success:false,message:message||'Request failed',errorCode:code||'SERVER_ERROR',data:data||null})).setMimeType(ContentService.MimeType.JSON)}function appError_(message,code){const e=new Error(message);e.appCode=code||'SERVER_ERROR';return e}